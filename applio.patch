--- a/rvc/lib/algorithm/generators/hifigan_nsf.py
+++ b/rvc/lib/algorithm/generators/hifigan_nsf.py
@@ -44,8 +44,27 @@ class SourceModuleHnNSF(torch.nn.Module):
         )
         self.l_linear = torch.nn.Linear(harmonic_num + 1, 1)
         self.l_tanh = torch.nn.Tanh()
+        # Workaround for MPS backward zero-buffer crash: run this tiny module on CPU.
+        # The l_linear backward on MPS trips Apple's MPSCommandBufferImageCache 0-byte
+        # allocation assertion. The transfer is cheap (~50KB, unified memory on Apple Silicon).
+        self._force_cpu = False
+
+    def _apply(self, fn, *args, **kwargs):
+        # Override _apply so model.to('mps') doesn't move this submodule to MPS.
+        if self._force_cpu:
+            return self
+        return super()._apply(fn, *args, **kwargs)
 
     def forward(self, x: torch.Tensor, upsample_factor: int = 1):
+        orig_device = x.device
+        if self._force_cpu and orig_device.type != "cpu":
+            x_cpu = x.detach().cpu()
+            if x.requires_grad:
+                x_cpu.requires_grad_(True)
+            sine_wavs, uv, _ = self.l_sin_gen(x_cpu, upsample_factor)
+            sine_wavs = sine_wavs.to(dtype=self.l_linear.weight.dtype)
+            sine_merge = self.l_tanh(self.l_linear(sine_wavs))
+            return sine_merge.to(orig_device), None, None
         sine_wavs, uv, _ = self.l_sin_gen(x, upsample_factor)
         sine_wavs = sine_wavs.to(dtype=self.l_linear.weight.dtype)
         sine_merge = self.l_tanh(self.l_linear(sine_wavs))
